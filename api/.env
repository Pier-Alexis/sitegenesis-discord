PORT=3000
API_KEY=REDACTED
DB_PATH=./database.sqlite

# Community moderation worker
COMMUNITY_MODERATION_ENABLED=true
COMMUNITY_MODERATION_INTERVAL_MS=5000
ROBLOX_GROUP_ID=165095337
ROBLOX_OPEN_CLOUD_API_KEY=REDACTED

# URL templates must include {groupId} and {userId}
# Example template shape:
# https://apis.roblox.com/cloud/v2/groups/{groupId}/members/{userId}:ban
ROBLOX_SET_GROUP_RANK_ENDPOINT_TEMPLATE=https://apis.roblox.com/cloud/v2/groups/{groupId}/memberships/{membershipId}:assignRole
ROBLOX_SET_GROUP_RANK_METHOD=POST

# Optional HTTP method overrides
ROBLOX_GROUP_BAN_METHOD=POST
ROBLOX_GROUP_UNBAN_METHOD=POST

ROBLOX_LIST_MEMBERSHIPS_ENDPOINT=https://apis.roblox.com/cloud/v2/groups/{groupId}/memberships

ROBLOX_ASSIGN_ROLE_ENDPOINT=https://apis.roblox.com/cloud/v2/groups/{groupId}/memberships/{membershipId}:assignRole
ROBLOX_ASSIGN_ROLE_METHOD=POST

ROBLOX_UNASSIGN_ROLE_ENDPOINT=https://apis.roblox.com/cloud/v2/groups/{groupId}/memberships/{membershipId}:unassignRole
ROBLOX_UNASSIGN_ROLE_METHOD=POST